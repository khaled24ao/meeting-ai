# ===========================================
# MeetingAI Environment Configuration Example
# ===========================================

# --- Required: Groq API Key ---
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Required: Flask Secret Key ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# --- Required: Client API Keys ---
# Users must provide one of these in the X-API-Key header
# Format: comma-separated list
ALLOWED_API_KEYS=key1,key2

# --- Optional: Server configuration ---
PORT=7860
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://yourdomain.com

# --- Optional: AI/ML Configuration ---
AI_MODEL=llama-3.1-8b-instant
WHISPER_MODEL=tiny
MAX_UPLOAD_SIZE_MB=25
MAX_TRANSCRIPT_LENGTH=4000
AI_TEMPERATURE=0.5
AI_MAX_TOKENS=1024

# --- Optional: Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=86400